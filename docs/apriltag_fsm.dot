digraph AprilTagPrecisionLandingFSM {
  graph [
    rankdir=TB,
    bgcolor="white",
    pad="0.35",
    nodesep="0.65",
    ranksep="0.85",
    splines=polyline,
    fontsize=24,
    fontname="Arial",
    label="AprilTag Precision Landing Finite State Machine",
    labelloc=t
  ];

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#f8fafc",
    color="#334155",
    penwidth=2,
    fontname="Arial",
    fontsize=20,
    margin="0.18,0.12"
  ];

  edge [
    color="#334155",
    penwidth=1.8,
    fontname="Arial",
    fontsize=15,
    arrowsize=0.8
  ];

  start [label="START", shape=oval, fillcolor="#dcfce7", color="#166534"];
  init [label="INIT\npublish warmup setpoints"];
  takeoff [label="TAKEOFF\narm + climb to cruise altitude"];
  retry [label="Retry Offboard / Arm", fillcolor="#fef3c7", color="#92400e"];
  gimbal [label="GIMBAL_DOWN\npitch camera to -90 deg"];
  search [label="SEARCH\ncamera-based search pattern"];
  approach [label="HORIZONTAL_APPROACH\ncenter selected tag in image"];
  descend [label="DESCEND_OVER_TARGET\ndescend while correcting XY"];
  lost [label="TARGET_LOST\nrecovery on selected tag"];
  grace [label="Continue slowly\non last good target", fillcolor="#fef3c7", color="#92400e"];
  final [label="FINAL_APPROACH\ncontinue near ground"];
  land [label="LAND\nPX4 land + disarm"];
  force [label="Force disarm fallback\nif PX4 says not landed", fillcolor="#fee2e2", color="#991b1b"];
  done [label="DONE", shape=oval, fillcolor="#dcfce7", color="#166534"];
  timeout [label="Normal PX4 land\nsearch timeout", fillcolor="#fee2e2", color="#991b1b"];

  start -> init;
  init -> takeoff [label="WARMUP_SEC done"];

  takeoff -> retry [label="not armed / not Offboard"];
  retry -> takeoff;
  takeoff -> gimbal [label="altitude ~= 5m"];

  gimbal -> search [label="gimbal settled"];

  search -> search [label="selected tag not visible"];
  search -> approach [label="selected target_tag_id visible"];
  search -> timeout [label="SEARCH_TIMEOUT"];
  timeout -> done;

  approach -> approach [label="fresh selected-tag frame\nupdate target + stream LANDING_TARGET"];
  approach -> descend [label="visual_error < PLD_HACC_RAD\nfor CENTER_CONFIRM_COUNT"];
  approach -> lost [label="target lost / bad correction"];
  approach -> lost [label="ALIGN_TIMEOUT"];

  descend -> descend [label="correct XY + descend\nstream LANDING_TARGET"];
  descend -> approach [label="drift too large"];
  descend -> lost [label="target lost / correction unavailable"];
  descend -> final [label="altitude <= PLD_FAPPR_ALT"];

  lost -> approach [label="reacquired from approach"];
  lost -> descend [label="reacquired from descent"];
  lost -> grace [label="during descent grace"];
  grace -> lost [label="keep checking target"];
  lost -> final [label="low altitude reached"];
  lost -> land [label="lost too long / max search attempts"];

  final -> final [label="target visible: update\nnot visible: use last target"];
  final -> land [label="altitude ~= 0.1m"];

  land -> land [label="send NAV_LAND / disarm"];
  land -> force [label="still says not landed\nafter FORCE_DISARM_DELAY"];
  force -> land;
  land -> done [label="disarmed"];
}
